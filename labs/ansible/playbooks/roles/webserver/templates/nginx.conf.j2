# nginx site config — generated by Ansible
# Template: roles/webserver/templates/nginx.conf.j2
# Do NOT edit manually — Ansible will overwrite changes.
server {
    listen {{ server_port }};
    server_name {{ server_name }};

    root {{ web_root }};
    index index.html;

    access_log /var/log/nginx/ansible-lab-access.log;
    error_log  /var/log/nginx/ansible-lab-error.log;

    location / {
        try_files $uri $uri/ =404;
    }
}
